ARG BASE_IMAGE=vtautoboat/development_image_base:latest
FROM ${BASE_IMAGE}

USER root

# Install toolchain and dependencies (move from script to Dockerfile for better layering)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc-arm-none-eabi \
    build-essential \
    libstdc++-arm-none-eabi-newlib \
    libusb-1.0-0-dev \
    doxygen \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /tmp/autoboat_scripts
COPY .devcontainer/devcontainer_variants/install_firmware_dependencies_helper_script.sh /tmp/autoboat_scripts/install_firmware_dependencies_helper_script.sh

# Create a sudo shim to allow the script to execute sudo commands as root during build
RUN echo '#!/bin/sh\nexec "$@"' > /usr/local/bin/sudo && chmod +x /usr/local/bin/sudo

# Run the script, then clean up build artifacts and .git history in a single layer
# to prevent Docker from persisting the intermediate bloat
RUN HOME=/home/autoboat_user bash /tmp/autoboat_scripts/install_firmware_dependencies_helper_script.sh \
    && (find /opt/autoboat/firmware_dependencies -name '.git' -type d -exec rm -rf {} + 2>/dev/null || true) \
    && (find /opt/autoboat/firmware_dependencies -name 'CMakeFiles' -type d -exec rm -rf {} + 2>/dev/null || true) \
    && (find /opt/autoboat/firmware_dependencies -name 'CMakeCache.txt' -delete 2>/dev/null || true) \
    && rm -rf /tmp/autoboat_scripts \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Fix permissions and clean up
RUN chown -R autoboat_user:autoboat_user /home/autoboat_user && rm /usr/local/bin/sudo

USER autoboat_user


RUN echo "export DEVCONTAINER_VARIANT=firmware_dependencies" >> ~/.bashrc


CMD ["/bin/bash"]
