ARG BASE_IMAGE=vtautoboat/development_image:latest
FROM ${BASE_IMAGE}


RUN mkdir -p /tmp/autoboat_scripts

COPY .devcontainer/devcontainer_variants/install_microros_helper_script.sh /tmp/autoboat_scripts/install_microros_helper_script.sh
RUN bash /tmp/autoboat_scripts/install_microros_helper_script.sh


RUN echo "export DEVCONTAINER_VARIANT=microros" >> ~/.bashrc


CMD ["/bin/bash"]
