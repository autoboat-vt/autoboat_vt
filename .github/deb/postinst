#!/bin/bash
set -e

# 1. Create the profile.d script for system-wide login shells
cat > /etc/profile.d/autoboat-vt.sh << 'EOF'
# Sourced automatically by /etc/profile.d — do not edit manually.
# Installed by the autoboat-vt Debian package.
if [ -f /opt/ros/humble/setup.bash ]; then
    source /opt/ros/humble/setup.bash
fi
if [ -f /opt/autoboat/install/setup.bash ]; then
    source /opt/autoboat/install/setup.bash
fi

# Micro-ROS environment configuration
export MICROROS_DIR="/opt/autoboat/microros"
export PICO_SDK_PATH="${MICROROS_DIR}/dependencies/pico-sdk"
export PICO_MICROROS_SDK_PATH="${MICROROS_DIR}/dependencies/micro_ros_raspberrypi_pico_sdk"
export PICOTOOL_PATH="${MICROROS_DIR}/dependencies/picotool"

# Source micro_ros_agent if it exists
if [ -f "${MICROROS_DIR}/dependencies/micro_ros_agent/install/local_setup.bash" ]; then
    source "${MICROROS_DIR}/dependencies/micro_ros_agent/install/local_setup.bash"
fi

# Aliases for Pico development
alias picotool="${PICOTOOL_PATH}/build/picotool"
alias picotool_load="sudo ${PICOTOOL_PATH}/build/picotool load"
alias picotool_reboot="sudo ${PICOTOOL_PATH}/build/picotool reboot"
EOF

chmod +x /etc/profile.d/autoboat-vt.sh

# 2. Reload udev rules to apply the new picotool rules
if command -v udevadm > /dev/null 2>&1; then
    echo "Reloading udev rules..."
    udevadm control --reload-rules && udevadm trigger || true
fi

# 3. Automatically update the current user's .bashrc for future interactive shells
if [ -n "$SUDO_USER" ]; then
    USER_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
    BASHRC="${USER_HOME}/.bashrc"
    SOURCE_LINE="source /etc/profile.d/autoboat-vt.sh"

    if [ -f "$BASHRC" ]; then
        if ! grep -qF "$SOURCE_LINE" "$BASHRC"; then
            echo -e "\n# Added by autoboat-vt installation\n$SOURCE_LINE" >> "$BASHRC"
            echo "Environment correctly configured for user: $SUDO_USER in $BASHRC"
        fi
    fi
fi

echo "--------------------------------------------------------"
echo "autoboat-vt: installed successfully!"
echo "--------------------------------------------------------"
echo "To activate the environment in your CURRENT terminal, run:"
echo "  source /etc/profile.d/autoboat-vt.sh"
echo ""
echo "Future terminals will have it enabled automatically."
echo "Then use: ros2 run autopilot_cpp motorboat_autopilot"
echo "--------------------------------------------------------"
