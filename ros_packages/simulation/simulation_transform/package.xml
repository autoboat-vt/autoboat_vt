<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>simulation_transform</name>
  <version>1.0.0</version>
  <description>Transforms the data that the simulation natively outputs into formats/ units/ standards the autopilot can easily understand</description>
  <maintainer email="autoboat@vt.edu">autoboatvt</maintainer>
  <license>http://www.apache.org/licenses/LICENSE-2.0</license>

  <test_depend>ament_copyright</test_depend>
  <test_depend>ament_flake8</test_depend>
  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
